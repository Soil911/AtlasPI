# AtlasPI — Configurazione ambiente
# Copia questo file in .env e personalizza

# Database: SQLite (dev) o PostgreSQL+PostGIS (prod)
# DATABASE_URL=sqlite:///data/atlaspi.db
# DATABASE_URL=postgresql://user:password@localhost:5432/atlaspi

# Server
HOST=127.0.0.1
PORT=10100
RELOAD=true

# CORS (origini permesse, separate da virgola)
CORS_ORIGINS=*

# Logging: INFO, DEBUG, WARNING, ERROR
LOG_LEVEL=INFO
# Formato: "json" (produzione) o "text" (sviluppo)
LOG_FORMAT=text

# Rate limiting (richieste/periodo)
RATE_LIMIT=60/minute

# Seed automatico dati demo all'avvio
AUTO_SEED=true
