    given-names: "Clirim"
    affiliation: "CRA (Cra Srl)"
version: "6.1.1"
date-released: "2026-04-14"
license: "Apache-2.0"
repository-code: "https://github.com/Soil911/AtlasPI"
url: "https://atlaspi.cra-srl.com"
type: software
keywords:
  - historical-geography
  - historical-gis
  - rest-api
  - ai-agents
  - mcp-server
  - geojson
  - digital-humanities
  - open-data
