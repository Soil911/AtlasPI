{
  "name": "atlaspi-client",
  "version": "0.2.0",
  "description": "Official JavaScript/TypeScript client for the AtlasPI Historical Geography API — free, public, no-auth REST API with 862 historical entities from 4500 BCE to 2024.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "atlaspi",
    "historical-geography",
    "history",
    "geojson",
    "ai-agents",
    "mcp",
    "boundaries",
    "typescript"
  ],
  "author": "AtlasPI Project",
  "license": "Apache-2.0",
  "homepage": "https://atlaspi.cra-srl.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Soil911/AtlasPI.git",
    "directory": "sdk-js"
  },
  "bugs": {
    "url": "https://github.com/Soil911/AtlasPI/issues"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
